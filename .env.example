# URL of the running carmen-inventory-frontend instance under test.
E2E_BASE_URL=http://localhost:3000

# Path to the carmen-inventory-frontend repo used for the Playwright webServer.
# Resolved relative to this project's root.
E2E_FRONTEND_DIR=../carmen-inventory-frontend

# Set to "1" to disable Playwright's webServer and test against an already
# running instance (e.g. staging).
E2E_NO_WEBSERVER=0

# Google Sheets sync (optional) — used by `bun e2e:sync` to upsert test
# results from tests/results/*.csv back to a spreadsheet. Set these in
# .env.local (do NOT commit). See scripts/sync-test-results.ts header for
# the full setup procedure.
GOOGLE_SHEETS_SA_KEY_PATH=/absolute/path/to/service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=
